import subprocess
import time
import re

DEFEND_EXEC = "./defend_2"   # 防禦端編譯後
ATTACK_EXEC = "./attack_2"   # 攻擊端編譯後

print("=== Purple Team：憑證攻擊 × 異常登入偵測 ===\n")

# 啟動防禦端
defender = subprocess.Popen(
    [DEFEND_EXEC],
    stdin=subprocess.PIPE,
    stdout=subprocess.PIPE,
    text=True,
    bufsize=1
)

# 啟動攻擊端
attacker = subprocess.Popen(
    [ATTACK_EXEC],
    stdout=subprocess.PIPE,
    text=True,
    bufsize=1
)

while True:
    atk_line = attacker.stdout.readline()
    if not atk_line:
        break

    if atk_line.startswith("TRY_PASSWORD:"):
        password = atk_line.strip().split(":")[1]
        print(f"[RED ] 嘗試密碼：{password}")

        # 等防禦端準備好
        while True:
            def_line = defender.stdout.readline()
            if "WAITING_FOR_PASSWORD" in def_line:
                break
            if def_line.strip():
                print(f"[BLUE] {def_line.strip()}")

        # 傳送密碼
        defender.stdin.write(password + "\n")
        defender.stdin.flush()

        # 讀防禦端回應
        response = defender.stdout.readline()
        if response:
            if "登入成功" in response:
                print(f"[BLUE] ✅ {response.strip()}")
                break
            elif "封鎖" in response:
                print(f"[BLUE] 🚨 {response.strip()}")
                break
            else:
                print(f"[BLUE] ❌ {response.strip()}")

    time.sleep(0.5)

attacker.terminate()
defender.terminate()
print("\n=== 攻防示範結束 ===")
