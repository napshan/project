import subprocess
import time
import os
import sys
import threading
import re
import shutil

# 1. 確保工作目錄正確
SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
os.chdir(SCRIPT_DIR)

class Colors:
    RED = '\033[91m'
    GREEN = '\033[92m'
    YELLOW = '\033[93m'
    BLUE = '\033[94m'
    PURPLE = '\033[95m'
    CYAN = '\033[96m'
    RESET = '\033[0m'
    BOLD = '\033[1m'

def get_executable_names():
    if os.name == 'nt':
        atk_name = "attack_1.exe"
        def_name = "defend_1.exe"
    else:
        atk_name = "attack_1"
        def_name = "defend_1"
    return os.path.join(SCRIPT_DIR, atk_name), os.path.join(SCRIPT_DIR, def_name)

def check_compiler():
    if shutil.which("g++") is None:
        print(f"{Colors.RED}[ERROR] 找不到 g++ 編譯器！{Colors.RESET}")
        return False
    return True

def cleanup_stale_processes():
    print(f"{Colors.YELLOW}[SYSTEM] 清理殘留行程...{Colors.RESET}")
    try:
        if os.name == 'nt':
            subprocess.run("taskkill /F /IM attack_1.exe", shell=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            subprocess.run("taskkill /F /IM defend_1.exe", shell=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        else:
            subprocess.run("pkill -9 -f attack_1", shell=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            subprocess.run("pkill -9 -f defend_1", shell=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception:
        pass

def compile_cpp():
    print(f"{Colors.YELLOW}[SYSTEM] 正在準備環境...{Colors.RESET}")
    print(f"{Colors.YELLOW}[SYSTEM] 工作目錄: {SCRIPT_DIR}{Colors.RESET}")
    
    if not check_compiler():
        return False

    if not os.path.exists("attack_1.cpp") or not os.path.exists("defend_1.cpp"):
        print(f"{Colors.RED}[ERROR] 找不到 cpp 原始碼！{Colors.RESET}")
        return False

    cleanup_stale_processes()
    print(f"{Colors.YELLOW}[SYSTEM] 正在編譯紅藍隊程式碼...{Colors.RESET}")
    
    shell_cmd = True if os.name == 'nt' else False
    atk_path, def_path = get_executable_names()

    res_atk = subprocess.run(["g++", "attack_1.cpp", "-o", atk_path], shell=shell_cmd, capture_output=True, text=True, errors='replace')
    if res_atk.returncode != 0:
        print(f"{Colors.RED}[ERROR] attack_1.cpp 編譯失敗。\n{res_atk.stderr}{Colors.RESET}")
        return False
        
    res_def = subprocess.run(["g++", "defend_1.cpp", "-o", def_path], shell=shell_cmd, capture_output=True, text=True, errors='replace')
    if res_def.returncode != 0:
        print(f"{Colors.RED}[ERROR] defend_1.cpp 編譯失敗。\n{res_def.stderr}{Colors.RESET}")
        return False
        
    print(f"{Colors.GREEN}[SYSTEM] 編譯完成！{Colors.RESET}\n")
    return True

def run_demo():
    print(f"{Colors.YELLOW}[SYSTEM] 啟動紫隊演練腳本 (v2.5 Fix Mojibake)...{Colors.RESET}")
    TARGET_PASSWORD = "admin1234"

    # [關鍵修正] 強制使用 utf-8
    # 說明：您的 C++ 檔案是 UTF-8 編碼，但之前用 cp950 (Big5) 讀取導致亂碼。
    # 改回 utf-8 應該就能正確顯示中文。
    sys_encoding = 'utf-8'
    
    attack_exec, defend_exec = get_executable_names()
    print(f"{Colors.YELLOW}[SYSTEM] OS: {os.name}, Encoding: {sys_encoding}{Colors.RESET}")

    if not os.path.exists(defend_exec):
        print(f"{Colors.RED}[ERROR] 找不到檔案: {defend_exec}{Colors.RESET}")
        return

    try:
        defend_process = subprocess.Popen(
            [defend_exec],
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            encoding=sys_encoding,
            errors='replace',
            bufsize=0, 
            shell=False,
            cwd=SCRIPT_DIR
        )
    except Exception as e:
        print(f"{Colors.RED}[ERROR] 無法啟動程式: {e}{Colors.RESET}")
        return

    print(f"{Colors.BLUE}[BLUE TEAM] 初始化安全閘道器...{Colors.RESET}")
    time.sleep(1)
    print(f"{Colors.CYAN}[ADMIN] 設定管理者金鑰: {TARGET_PASSWORD}{Colors.RESET}")
    
    try:
        defend_process.stdin.write(TARGET_PASSWORD + "\n")
        defend_process.stdin.flush() 
        defend_process.stdin.write(TARGET_PASSWORD + "\n")
        defend_process.stdin.flush()
    except Exception as e:
        print(f"{Colors.RED}[ERROR] 初始化寫入失敗: {e}{Colors.RESET}")
        if defend_process: defend_process.terminate()
        return
    
    # [修改] 增加除錯輸出，顯示所有收到的訊息
    print(f"{Colors.YELLOW}[DEBUG] 等待藍隊回應 '系統初始化完成'...{Colors.RESET}")
    init_success = False
    start_time = time.time()
    
    # 增加等待時間到 10 秒
    while time.time() - start_time < 10: 
        line = defend_process.stdout.readline()
        if not line: break
        
        # 把每一行都印出來給你看
        print(f"  [RAW OUTPUT] {line.strip()}")
        
        # [關鍵修正] 只要看到中文成功訊息 OR 看到等待 Token 的英文訊息，都視為成功
        if "系統初始化完成" in line or "WAITING_FOR_TOKEN" in line:
            print(f"{Colors.BLUE}[BLUE TEAM] 系統已就緒: {line.strip()}{Colors.RESET}")
            init_success = True
            break

    if not init_success:
        print(f"{Colors.RED}[ERROR] 藍隊初始化失敗或超時。{Colors.RESET}")
        print(f"{Colors.YELLOW}可能原因：C++ 程式沒有輸出 '系統初始化完成' 或輸出緩衝區未刷新。{Colors.RESET}")
        if defend_process: defend_process.terminate()
        return

    print("-" * 60)
    print(f"{Colors.PURPLE}{Colors.BOLD}>>> 紫隊演練開始 <<<{Colors.RESET}")
    print("-" * 60)
    time.sleep(1)

    try:
        attack_process = subprocess.Popen(
            [attack_exec],
            stdout=subprocess.PIPE,
            text=True,
            encoding=sys_encoding,
            errors='replace',
            bufsize=0,
            shell=False,
            cwd=SCRIPT_DIR
        )
    except Exception as e:
        print(f"{Colors.RED}無法啟動紅隊: {e}{Colors.RESET}")
        if defend_process: defend_process.terminate()
        return

    try:
        while True:
            attack_line = attack_process.stdout.readline()
            if not attack_line:
                break 

            match = re.search(r"try:\s*(.+)", attack_line)
            if match:
                token_attempt = match.group(1).strip()
                print(f"{Colors.RED}[RED TEAM] 發送惡意 Payload: '{token_attempt}'{Colors.RESET}")

                while True:
                    def_line = defend_process.stdout.readline()
                    if "WAITING_FOR_TOKEN" in def_line:
                        break
                    if def_line.strip():
                        print(f"{Colors.BLUE}    └─ [LOG] {def_line.strip()}{Colors.RESET}")

                try:
                    defend_process.stdin.write(token_attempt + "\n")
                    defend_process.stdin.flush()
                except BrokenPipeError:
                    print("防禦者已關閉連線")
                    break
                
                result_line = defend_process.stdout.readline()
                
                if "[ALLOW]" in result_line:
                    print(f"{Colors.GREEN}{Colors.BOLD}    └─ [DEFENSE] ⚠ 警報：攻擊穿透防禦！ {result_line.strip()}{Colors.RESET}")
                elif "[BLOCK]" in result_line:
                    print(f"{Colors.BLUE}{Colors.BOLD}    └─ [DEFENSE] 🛡️ {result_line.strip()}{Colors.RESET}")
                elif "[DENY]" in result_line:
                    print(f"{Colors.BLUE}    └─ [DEFENSE] 🚫 {result_line.strip()}{Colors.RESET}")
                else:
                    print(f"{Colors.BLUE}    └─ [DEFENSE] {result_line.strip()}{Colors.RESET}")
                
                print("") 

            else:
                if attack_line.strip():
                    print(f"{Colors.YELLOW}[RED LOG] {attack_line.strip()}{Colors.RESET}")

    except KeyboardInterrupt:
        print("\n演練手動終止。")

    if attack_process: attack_process.terminate()
    if defend_process: defend_process.terminate()
    cleanup_stale_processes()
    print("-" * 60)
    print(f"{Colors.PURPLE}演練結束。{Colors.RESET}")

if __name__ == "__main__":
    if compile_cpp():
        run_demo()
